{
    "name": "control-mesh",
    "private": true,
    "version": "0.1.0",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "rollup -c",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart dev.jerez.sds.control-mesh\"",
        "dev": "streamdeck dev",
        "link": "streamdeck link dev.jerez.sds.control-mesh.sdPlugin",
        "restart": "streamdeck restart dev.jerez.sds.control-mesh",
        "validate": "streamdeck validate dev.jerez.sds.control-mesh.sdPlugin --no-update-check",
        "pack": "pnpm run build && streamdeck pack dev.jerez.sds.control-mesh.sdPlugin -f --no-update-check",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --max-warnings 0",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "@elgato/streamdeck": "2.1.0",
        "@modelcontextprotocol/sdk": "1.29.0",
        "bonjour-service": "^1.4.0"
    },
    "devDependencies": {
        "@workspace/sdpi-components": "workspace:*",
        "@elgato/cli": "1.7.4",
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/node": "~24.12.4",
        "rollup": "^4.61.0",
        "tslib": "^2.8.1",
        "typescript": "^5.2.2"
    }
}
