{
    "name": "usb-link",
    "private": true,
    "version": "0.1.0",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "build": "rollup -c",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart dev.jerez.sds.usb-link\"",
        "dev": "streamdeck dev",
        "link": "streamdeck link dev.jerez.sds.usb-link.sdPlugin",
        "restart": "streamdeck restart dev.jerez.sds.usb-link",
        "validate": "streamdeck validate dev.jerez.sds.usb-link.sdPlugin --no-update-check",
        "pack": "pnpm run build && streamdeck pack dev.jerez.sds.usb-link.sdPlugin -f --no-update-check",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --max-warnings 0",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "@elgato/streamdeck": "2.1.0"
    },
    "devDependencies": {
        "@workspace/sdpi-components": "workspace:*",
        "@elgato/cli": "1.7.4",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^15.2.2",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.1.0",
        "@types/node": "~24.12.4",
        "rollup": "^4.0.2",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2"
    }
}
