{
    "name": "sd-suite",
    "private": true,
    "version": "0.0.0",
    "license": "MIT",
    "packageManager": "pnpm@11.5.0",
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "changeset": "changeset",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "native:build": "turbo run native:build",
        "native:stage": "turbo run native:stage",
        "native:test": "turbo run native:test",
        "native:validate": "turbo run native:validate",
        "prepare": "husky",
        "plugin:create": "node tools/create-streamdeck-plugin.mjs",
        "plugin:pack": "turbo run pack",
        "plugin:validate": "turbo run validate",
        "release:plan": "node tools/plugin-release.mjs",
        "release:native": "turbo run release:native",
        "release:status": "changeset status",
        "release:version": "changeset version && node tools/plugin-release.mjs --sync-manifests",
        "test": "vitest run --passWithNoTests && turbo run test",
        "test:coverage": "vitest run --coverage --passWithNoTests",
        "test:unit": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "typecheck": "turbo run typecheck",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "devDependencies": {
        "@changesets/cli": "2.31.1",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@elgato/cli": "1.7.4",
        "@eslint/js": "^10.0.1",
        "@types/node": "~24.12.4",
        "@vitest/coverage-v8": "3.2.6",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.3",
        "turbo": "^2.6.3",
        "typescript": "^5.2.2",
        "typescript-eslint": "8.60.0",
        "vitest": "3.2.6"
    },
    "engines": {
        "node": ">=24.16.0 <25",
        "pnpm": ">=11.5.0 <12"
    }
}
