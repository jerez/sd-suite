{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "*.sdPlugin/bin/**", "*.sdPlugin/ui/*.js"]
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "outputs": []
        },
        "lint": {
            "dependsOn": ["^lint"],
            "outputs": []
        },
        "native:build": {
            "cache": false,
            "outputs": [".native/**"]
        },
        "native:stage": {
            "cache": false,
            "outputs": []
        },
        "native:test": {
            "cache": false,
            "outputs": []
        },
        "native:validate": {
            "cache": false,
            "outputs": []
        },
        "validate": {
            "dependsOn": ["build"],
            "outputs": []
        },
        "pack": {
            "dependsOn": ["build", "validate"],
            "outputs": ["*.streamDeckPlugin"]
        },
        "test": {
            "dependsOn": ["^build"],
            "outputs": []
        }
    }
}
